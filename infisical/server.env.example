# Infisical server environment — SELF-HOSTED.
# Copy to server.env and fill in real values. Never commit server.env.

# REQUIRED — generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-me-64-hex-chars
JWT_SIGNUP_SECRET=replace-me-random-string

# REQUIRED — public URL of the Infisical instance
SITE_URL=http://localhost

# REQUIRED — generate with: openssl rand -hex 32
AUTH_SECRET=replace-me-64-hex-chars

# Database (matches docker-compose)
DB_CONNECTION_URI=postgres://infisical:change-me@postgres:5432/infisical

# Redis
REDIS_URL=redis://redis:6379

# SMTP (required for invite emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=Infisical
SMTP_FROM_ADDRESS=

# Optional
INVITE_MODE=email
